{
  "kind": "collectionType",
  "collectionName": "videos",
  "info": {
    "singularName": "video",
    "pluralName": "videos",
    "displayName": "Video",
    "description": "Video works"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "video": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["videos"]
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "Story": {
      "type": "text"
    },
    "IsFeatured": {
      "type": "boolean",
      "default": false
    },
    "Spend": {
      "type": "biginteger"
    },
    "ROI_7D": {
      "type": "decimal"
    },
    "Rank": {
      "type": "integer",
      "default": 0
    },
    "CTR": {
      "type": "decimal"
    },
    "LaunchDate": {
      "type": "date"
    }
  }
}
